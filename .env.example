# React App Environment Variables
REACT_APP_API_URL=https://api.aislefinder3000.com

# Backend Environment Variables (for deployment)
KROGER_CLIENT_ID=your_kroger_client_id_here
KROGER_CLIENT_SECRET=your_kroger_client_secret_here

# Enables photo capture of grocery lists (/api/photo-to-list); without it the
# endpoint returns 503 and the camera button reports it's not set up.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Enables the local debug routes (/debug, /api/debug-kroger) and Flask debug
# mode. Deployed servers must set this to production (see DEPLOYMENT.md).
FLASK_ENV=development